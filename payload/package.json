{
  "name": "riftmatch-cms",
  "version": "1.0.0",
  "description": "Payload CMS for RiftMatch",
  "main": "dist/server.js",
  "scripts": {
    "build": "payload build && tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "generate:types": "payload generate:types",
    "migrate": "node_modules/.bin/ts-node-dev --transpile-only --exit-child src/migrations/runner.ts",
    "migrate:prod": "node dist/migrations/runner.js"
  },
  "dependencies": {
    "payload": "^2.32.3",
    "@payloadcms/bundler-webpack": "^1.0.9",
    "@payloadcms/db-mongodb": "^1.7.5",
    "@payloadcms/richtext-slate": "^1.5.2",
    "express": "^4.18.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.0.4"
  }
}
