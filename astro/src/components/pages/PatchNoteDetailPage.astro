---
import Layout from '../../layouts/Layout.astro'
import AffiliateBlock from '../AffiliateBlock.astro'
import SourceLink from '../SourceLink.astro'

const { slug } = Astro.params
const PAYLOAD_URL = import.meta.env.PAYLOAD_API_URL || 'http://payload:3000'
const locale = Astro.cookies.get('locale')?.value || 'fr'

let patch: any = null
try {
  const res = await fetch(`${PAYLOAD_URL}/api/patch-notes?where[slug][equals]=${slug}&where[status][equals]=published&limit=1`)
  const data = await res.json()
  patch = data.docs?.[0] ?? null
} catch { /* silent fail */ }

if (!patch) return Astro.redirect('/patch-notes')

function formatDate(d: string) {
  if (!d) return ''
  return new Date(d).toLocaleDateString('fr-FR', {
    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
  })
}

function formatDateShort(d: string) {
  if (!d) return ''
  return new Date(d).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' })
}

// ── Rich text renderer (Slate → HTML) ──────────────────────────
type SlateNode = {
  type?: string; text?: string; bold?: boolean; italic?: boolean
  underline?: boolean; strikethrough?: boolean; code?: boolean
  url?: string; newTab?: boolean; children?: SlateNode[]
}

function slugify(text: string) {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')
}

function renderNodes(nodes: SlateNode[], withIds = false): string {
  if (!nodes?.length) return ''
  return nodes.map(n => renderNode(n, withIds)).join('')
}

function renderNode(node: SlateNode, withIds = false): string {
  if (node.text !== undefined) {
    let t = node.text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    if (node.bold)          t = `<strong>${t}</strong>`
    if (node.italic)        t = `<em>${t}</em>`
    if (node.underline)     t = `<u>${t}</u>`
    if (node.strikethrough) t = `<s>${t}</s>`
    if (node.code)          t = `<code>${t}</code>`
    return t
  }
  const inner = renderNodes(node.children || [], withIds)
  switch (node.type) {
    case 'h1': return `<h1>${inner}</h1>`
    case 'h2': {
      const id = withIds ? ` id="${slugify(node.children?.map((c: SlateNode) => c.text || '').join('') || '')}"` : ''
      return `<h2${id}>${inner}</h2>`
    }
    case 'h3': return `<h3>${inner}</h3>`
    case 'h4': return `<h4>${inner}</h4>`
    case 'ul': return `<ul>${inner}</ul>`
    case 'ol': return `<ol>${inner}</ol>`
    case 'li': return `<li>${inner}</li>`
    case 'blockquote': return `<blockquote>${inner}</blockquote>`
    case 'link': {
      const href = node.url || '#'
      const target = node.newTab ? ' target="_blank" rel="noopener noreferrer"' : ''
      return `<a href="${href}"${target}>${inner}</a>`
    }
    default: return inner ? `<p>${inner}</p>` : ''
  }
}

// ToC from H2 headings
const tocItems = (patch.content || [])
  .filter((n: SlateNode) => n.type === 'h2')
  .map((n: SlateNode) => ({
    text: n.children?.map((c: SlateNode) => c.text || '').join('') || '',
    id: slugify(n.children?.map((c: SlateNode) => c.text || '').join('') || ''),
  }))

const htmlContent = renderNodes(patch.content || [], true)

// Highlight text analysis: detect buff (🔺 ▲ ↑ +) vs nerf (🔻 ▼ ↓ -)
function classifyHighlight(text: string): 'buff' | 'nerf' | 'neutral' {
  if (/🔺|▲|↑|\+\d|buff|augment|bonus/i.test(text)) return 'buff'
  if (/🔻|▼|↓|\-\d|nerf|réduit|diminué/i.test(text)) return 'nerf'
  return 'neutral'
}

const isLive = patch.type === 'live'
const isPbe  = patch.type === 'pbe'
---

<Layout
  title={`${patch.title} | RiftMatch Patch Notes`}
  description={patch.excerpt || `Patch ${patch.version} — Notes de mise à jour League of Legends`}
  image={patch.coverImage || '/og-image.jpg'}
>
  <Fragment slot="head">
    {patch.publishedAt && <meta property="article:published_time" content={patch.publishedAt} />}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": patch.title,
      "description": patch.excerpt,
      "datePublished": patch.publishedAt,
      "publisher": { "@type": "Organization", "name": "RiftMatch" }
    })} />
  </Fragment>

  <div class="pn-detail">

    <!-- ══ HERO SECTION ══════════════════════════════════════ -->
    <div class="pn-hero" class:list={[isLive ? 'hero--live' : 'hero--pbe']}>
      {patch.coverImage && (
        <div class="hero-bg">
          <img src={patch.coverImage} alt="" aria-hidden="true" class="hero-bg-img" loading="eager" />
          <div class="hero-bg-overlay"></div>
        </div>
      )}

      <div class="hero-content">
        <!-- Breadcrumb -->
        <nav class="hero-breadcrumb" aria-label="Fil d'Ariane">
          <a href="/">Accueil</a>
          <span aria-hidden="true">›</span>
          <a href="/patch-notes">Patch Notes</a>
          <span aria-hidden="true">›</span>
          <span>{patch.version}</span>
        </nav>

        <!-- Version + type badges -->
        <div class="hero-badges">
          <div class="version-chip">
            <span class="version-label">PATCH</span>
            <span class="version-number">{patch.version}</span>
          </div>
          {isLive && (
            <div class="type-chip type-chip--live">
              <span class="type-dot type-dot--live"></span>
              Live — Officiel
            </div>
          )}
          {isPbe && (
            <div class="type-chip type-chip--pbe">
              <span class="type-dot type-dot--pbe"></span>
              PBE — Preview
            </div>
          )}
        </div>

        <h1 class="hero-title">{patch.title}</h1>

        {patch.excerpt && (
          <p class="hero-excerpt">{patch.excerpt}</p>
        )}

        <div class="hero-meta">
          {patch.publishedAt && (
            <span class="hero-meta-item">
              <svg viewBox="0 0 24 24" fill="none" width="15" height="15" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/>
                <path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
              {formatDate(patch.publishedAt)}
            </span>
          )}
        </div>
      </div>
    </div>

    <!-- ══ HIGHLIGHTS BAR ════════════════════════════════════ -->
    {patch.highlights && patch.highlights.length > 0 && (
      <div class="highlights-bar">
        <div class="highlights-bar-inner">
          <div class="highlights-header">
            <svg viewBox="0 0 24 24" fill="none" width="18" height="18" aria-hidden="true">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
            </svg>
            <span>Points clés du patch {patch.version}</span>
          </div>
          <ul class="highlights-list">
            {patch.highlights.map((h: any) => {
              const kind = classifyHighlight(h.text)
              return (
                <li class={`highlight-item highlight-item--${kind}`}>
                  {kind === 'buff' && (
                    <svg class="highlight-icon" viewBox="0 0 16 16" fill="currentColor" width="12" height="12" aria-hidden="true">
                      <path d="M8 2l2 4h4l-3 3 1 4-4-2.5L4 13l1-4L2 6h4z"/>
                    </svg>
                  )}
                  {kind === 'nerf' && (
                    <svg class="highlight-icon" viewBox="0 0 16 16" fill="currentColor" width="12" height="12" aria-hidden="true">
                      <path d="M8 14l-2-4H2l3-3-1-4 4 2.5L12 3l-1 4 3 3h-4z"/>
                    </svg>
                  )}
                  {kind === 'neutral' && (
                    <svg class="highlight-icon" viewBox="0 0 16 16" fill="currentColor" width="12" height="12" aria-hidden="true">
                      <circle cx="8" cy="8" r="3"/>
                    </svg>
                  )}
                  <span>{h.text}</span>
                </li>
              )
            })}
          </ul>
        </div>
      </div>
    )}

    <!-- ══ MAIN BODY : ToC + Content ════════════════════════ -->
    <div class="pn-body">

      <!-- ── Sidebar ToC ──────────────────────────────────── -->
      {tocItems.length > 0 && (
        <aside class="pn-sidebar" aria-label="Sommaire">
          <div class="toc-card">
            <p class="toc-title">
              <svg viewBox="0 0 24 24" fill="none" width="14" height="14" aria-hidden="true">
                <path d="M4 6h16M4 12h12M4 18h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
              Sommaire
            </p>
            <nav>
              <ol class="toc-list">
                {tocItems.map((item: any, i: number) => (
                  <li>
                    <a href={`#${item.id}`} class="toc-link">
                      <span class="toc-num">{String(i + 1).padStart(2, '0')}</span>
                      {item.text}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          </div>

          <!-- Quick info card -->
          <div class="sidebar-info-card">
            <p class="sidebar-info-title">Informations</p>
            <dl class="sidebar-dl">
              <dt>Version</dt>
              <dd class="dd-version">{patch.version}</dd>
              <dt>Type</dt>
              <dd class={isLive ? 'dd-live' : 'dd-pbe'}>{isLive ? '✅ Live' : '🧪 PBE'}</dd>
              {patch.publishedAt && (
                <>
                  <dt>Date</dt>
                  <dd>{formatDateShort(patch.publishedAt)}</dd>
                </>
              )}
              {patch.highlights?.length > 0 && (
                <>
                  <dt>Changements</dt>
                  <dd>{patch.highlights.length} points clés</dd>
                </>
              )}
            </dl>
          </div>

          <!-- Quiz CTA -->
          <div class="sidebar-quiz">
            <p class="sidebar-quiz-label">Après ce patch</p>
            <p class="sidebar-quiz-title">Ton champion idéal ?</p>
            <a href="/quiz" class="sidebar-quiz-btn">Faire le quiz →</a>
          </div>
        </aside>
      )}

      <!-- ── Rich text content ────────────────────────────── -->
      <article class="pn-content">
        {htmlContent ? (
          <div class="prose" set:html={htmlContent} />
        ) : (
          <div class="pn-no-content">
            <p>Le contenu détaillé de ce patch note n'est pas encore disponible.</p>
            <p>Revenez bientôt ou consultez la <a href="https://www.leagueoflegends.com/fr-fr/news/tags/patch-notes/" target="_blank" rel="noopener noreferrer">page officielle Riot</a>.</p>
          </div>
        )}

        <!-- ── Source officielle ────────────────────────── -->
        <SourceLink sourceUrl={patch.sourceUrl} locale={locale} />

        <!-- ── Affiliate block ──────────────────────────── -->
        <div class="pn-aff-wrap">
          <AffiliateBlock variant="banner" locale={locale} />
        </div>

        <!-- ── Back & navigation ────────────────────────── -->
        <nav class="pn-nav-bottom" aria-label="Navigation patch notes">
          <a href="/patch-notes" class="nav-back">
            ← Tous les patch notes
          </a>
          <a href="/quiz" class="nav-quiz">
            Trouver mon champion →
          </a>
        </nav>
      </article>

    </div>
  </div>
</Layout>

<style>
  /* ══ LAYOUT ═══════════════════════════════════════════════ */
  .pn-detail {
    max-width: 100%;
  }

  /* ══ HERO ═════════════════════════════════════════════════ */
  .pn-hero {
    position: relative;
    min-height: 380px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    margin-bottom: 0;
  }

  /* Gradient fallback without cover image */
  .pn-hero:not(:has(.hero-bg)) {
    background: linear-gradient(135deg, var(--dark2) 0%, var(--dark4) 100%);
  }
  .hero--live:not(:has(.hero-bg)) {
    background: linear-gradient(135deg, #0a140a 0%, #0e1118 50%, #0a1a0e 100%);
  }
  .hero--pbe:not(:has(.hero-bg)) {
    background: linear-gradient(135deg, #140a1e 0%, #0e1118 50%, #1a0a2a 100%);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: brightness(0.5) saturate(0.8);
  }
  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(9,11,16,0.3) 0%, rgba(9,11,16,0.95) 100%),
      linear-gradient(to right, rgba(9,11,16,0.0) 0%, transparent 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Breadcrumb ────────────────────────────────────────── */
  .hero-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-dim);
    flex-wrap: wrap;
  }
  .hero-breadcrumb a {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .hero-breadcrumb a:hover { color: var(--gold); }
  .hero-breadcrumb span:last-child { color: var(--text-muted); }

  /* ── Badges ────────────────────────────────────────────── */
  .hero-badges {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .version-chip {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid rgba(200,155,60,0.4);
    border-radius: 8px;
    overflow: hidden;
  }
  .version-label {
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--dark);
    background: var(--gold);
    padding: 0.35rem 0.5rem;
    text-transform: uppercase;
  }
  .version-number {
    font-family: 'Russo One', sans-serif;
    font-size: 1.1rem;
    color: var(--gold);
    padding: 0.2rem 0.75rem;
    background: rgba(200,155,60,0.1);
    letter-spacing: 0.05em;
  }
  .type-chip {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 6px;
  }
  .type-chip--live {
    color: #4ade80;
    background: rgba(34,197,94,0.12);
    border: 1px solid rgba(34,197,94,0.3);
  }
  .type-chip--pbe {
    color: #c084fc;
    background: rgba(168,85,247,0.12);
    border: 1px solid rgba(168,85,247,0.3);
  }
  .type-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }
  .type-dot--live {
    background: #4ade80;
    box-shadow: 0 0 8px #4ade80;
    animation: pulse-live 2s infinite;
  }
  .type-dot--pbe {
    background: #c084fc;
    box-shadow: 0 0 8px #c084fc;
  }
  @keyframes pulse-live {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.6; }
  }

  /* ── Hero title ────────────────────────────────────────── */
  .hero-title {
    font-family: 'Russo One', sans-serif;
    font-size: clamp(1.8rem, 4.5vw, 3rem);
    color: var(--text-light);
    line-height: 1.15;
    max-width: 700px;
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }
  .hero-excerpt {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 600px;
    line-height: 1.65;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .hero-meta-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-dim);
  }

  /* ══ HIGHLIGHTS BAR ═══════════════════════════════════════ */
  .highlights-bar {
    background: var(--dark2);
    border-top: 1px solid rgba(200,155,60,0.15);
    border-bottom: 1px solid var(--glass-border);
  }
  .highlights-bar-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.5rem;
  }
  .highlights-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Russo One', sans-serif;
    font-size: 0.9rem;
    color: var(--gold);
    margin-bottom: 1rem;
  }
  .highlights-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.6rem;
  }
  .highlight-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.6rem 0.85rem;
    border-radius: 7px;
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.4;
  }
  .highlight-item--buff {
    background: rgba(74,222,128,0.07);
    border: 1px solid rgba(74,222,128,0.2);
    color: #86efac;
  }
  .highlight-item--nerf {
    background: rgba(248,113,113,0.07);
    border: 1px solid rgba(248,113,113,0.2);
    color: #fca5a5;
  }
  .highlight-item--neutral {
    background: var(--dark3);
    border: 1px solid var(--glass-border);
    color: var(--text-muted);
  }
  .highlight-icon {
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
  .highlight-item--buff .highlight-icon   { color: #4ade80; }
  .highlight-item--nerf .highlight-icon   { color: #f87171; }
  .highlight-item--neutral .highlight-icon { color: var(--text-dim); }

  /* ══ BODY ═════════════════════════════════════════════════ */
  .pn-body {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 2.5rem;
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 5rem;
    align-items: start;
  }

  /* ══ SIDEBAR ══════════════════════════════════════════════ */
  .pn-sidebar {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── ToC card ──────────────────────────────────────────── */
  .toc-card {
    background: var(--dark3);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 1.25rem;
  }
  .toc-title {
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .toc-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    counter-reset: toc;
  }
  .toc-link {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.45rem 0.5rem;
    border-radius: 6px;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    color: var(--text-muted);
    transition: background 0.15s, color 0.15s;
    line-height: 1.3;
  }
  .toc-link:hover {
    background: var(--dark4);
    color: var(--gold-light);
  }
  .toc-num {
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--text-dim);
    flex-shrink: 0;
  }

  /* ── Info card ─────────────────────────────────────────── */
  .sidebar-info-card {
    background: var(--dark3);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 1.25rem;
  }
  .sidebar-info-title {
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.85rem;
  }
  .sidebar-dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.4rem 0.75rem;
    font-size: 0.82rem;
  }
  .sidebar-dl dt {
    color: var(--text-dim);
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 0.78rem;
  }
  .sidebar-dl dd {
    color: var(--text-muted);
    font-family: 'Inter', sans-serif;
  }
  .dd-version {
    font-family: 'Russo One', sans-serif;
    color: var(--gold);
    font-size: 0.9rem;
  }
  .dd-live { color: #4ade80; }
  .dd-pbe  { color: #c084fc; }

  /* ── Quiz sidebar CTA ──────────────────────────────────── */
  .sidebar-quiz {
    background: linear-gradient(135deg, rgba(200,155,60,0.12) 0%, rgba(11,196,227,0.06) 100%);
    border: 1px solid rgba(200,155,60,0.25);
    border-radius: 12px;
    padding: 1.25rem;
    text-align: center;
  }
  .sidebar-quiz-label {
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.35rem;
  }
  .sidebar-quiz-title {
    font-family: 'Russo One', sans-serif;
    font-size: 0.95rem;
    color: var(--text-light);
    margin-bottom: 0.85rem;
  }
  .sidebar-quiz-btn {
    display: inline-block;
    background: var(--gold);
    color: var(--dark);
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s;
    cursor: pointer;
  }
  .sidebar-quiz-btn:hover { background: var(--gold-light); }

  /* ══ CONTENT ══════════════════════════════════════════════ */
  .pn-content {}
  .pn-no-content {
