---
/**
 * ArticlePage — shared component used by all locale routes
 * /info/[slug]       → Astro.currentLocale = 'fr'
 * /en/info/[slug]    → Astro.currentLocale = 'en'
 * /es/info/[slug]    → Astro.currentLocale = 'es'
 */
import Layout from '../../layouts/Layout.astro'
import AffiliateBlock from '../AffiliateBlock.astro'
import { UI } from '../../i18n.js'

const { slug } = Astro.params
const PAYLOAD_URL = import.meta.env.PAYLOAD_API_URL || 'http://payload:3000'

// URL locale : 'fr' (default, sans préfixe) | 'en' | 'es'
const urlLocale = Astro.currentLocale || 'fr'
const cookieLocale = Astro.cookies.get('locale')?.value || 'fr'

// Redirect si l'utilisateur préfère une autre langue et est sur l'URL FR par défaut
if (urlLocale === 'fr' && cookieLocale !== 'fr') {
  return Astro.redirect(`/${cookieLocale}/info/${slug}`, 302)
}

const locale = urlLocale
const ta = (UI as any)[locale]?.articlePage || (UI as any).fr.articlePage

let page: any = null
try {
  // Try locale-specific first
  let res = await fetch(
    `${PAYLOAD_URL}/api/pages?where[slug][equals]=${slug}&where[locale][equals]=${locale}&limit=1`
  )
  let data = await res.json()
  page = data.docs?.[0] ?? null

  if (!page) {
    // Fallback: any locale (page not yet translated)
    res = await fetch(`${PAYLOAD_URL}/api/pages?where[slug][equals]=${slug}&limit=1`)
    data = await res.json()
    page = data.docs?.[0] ?? null
  }
} catch (e) {
  console.error('Could not fetch page:', e)
}

if (!page) return Astro.redirect('/404')

const template: 'article' | 'guide' | 'listicle' = page.template || 'article'

// ── Rich text renderer (Slate → HTML) ──────────────────────────
type SlateNode = {
  type?: string; text?: string; bold?: boolean; italic?: boolean
  underline?: boolean; strikethrough?: boolean; code?: boolean
  url?: string; newTab?: boolean; children?: SlateNode[]
}

function slugify(text: string) {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')
}

function renderNodes(nodes: SlateNode[], withIds = false): string {
  if (!nodes?.length) return ''
  return nodes.map(n => renderNode(n, withIds)).join('')
}

function renderNode(node: SlateNode, withIds = false): string {
  if (node.text !== undefined) {
    let t = node.text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    if (node.bold)          t = `<strong>${t}</strong>`
    if (node.italic)        t = `<em>${t}</em>`
    if (node.underline)     t = `<u>${t}</u>`
    if (node.strikethrough) t = `<s>${t}</s>`
    if (node.code)          t = `<code>${t}</code>`
    return t
  }
  const inner = renderNodes(node.children || [], withIds)
  switch (node.type) {
    case 'h1': return `<h1>${inner}</h1>`
    case 'h2': {
      const id = withIds ? ` id="${slugify(node.children?.map(c => c.text || '').join('') || '')}"` : ''
      return `<h2${id}>${inner}</h2>`
    }
    case 'h3': return `<h3>${inner}</h3>`
    case 'h4': return `<h4>${inner}</h4>`
    case 'ul':  return `<ul>${inner}</ul>`
    case 'ol':  return `<ol>${inner}</ol>`
    case 'li':  return `<li>${inner}</li>`
    case 'blockquote': return `<blockquote>${inner}</blockquote>`
    case 'link': {
      const href = node.url || '#'
      const target = node.newTab ? ' target="_blank" rel="noopener noreferrer"' : ''
      return `<a href="${href}"${target}>${inner}</a>`
    }
    default: return inner ? `<p>${inner}</p>` : ''
  }
}

// Extract h2 headings for ToC (guide template)
const tocItems = (page.content || [])
  .filter((n: SlateNode) => n.type === 'h2')
  .map((n: SlateNode) => {
    const text = (n.children || []).map((c: SlateNode) => c.text || '').join('')
    return { text, id: slugify(text) }
  })

// For listicle: split content at each h2 into sections
type Section = { title: string; nodes: SlateNode[] }
const sections: Section[] = []
if (template === 'listicle') {
  let current: Section | null = null
  for (const node of (page.content || [])) {
    if (node.type === 'h2') {
      if (current) sections.push(current)
      current = { title: (node.children || []).map((c: SlateNode) => c.text || '').join(''), nodes: [] }
    } else if (current) {
      current.nodes.push(node)
    }
  }
  if (current) sections.push(current)
}

const htmlContent = renderNodes(page.content || [], template === 'guide')

// Reading time
const words = htmlContent.replace(/<[^>]+>/g, '').split(/\s+/).filter(Boolean).length
const readingMin = Math.max(1, Math.round(words / 200))

// Locale-aware paths
const BASE = 'https://riftmatch.io'
const guidesPath = locale === 'fr' ? '/guides' : `/${locale}/guides`
const quizPath = '/quiz'  // pas de variante URL par locale
const canonicalUrl = locale === 'fr' ? `${BASE}/info/${page.slug}` : `${BASE}/${locale}/info/${page.slug}`
const inLanguage = locale === 'en' ? 'en' : locale === 'es' ? 'es' : 'fr'

// JSON-LD
const articleSchema = {
  '@context': 'https://schema.org', '@type': 'Article',
  headline: page.title, description: page.seo?.description || '',
  url: canonicalUrl,
  publisher: { '@type': 'Organization', name: 'RiftMatch', url: BASE },
  inLanguage, dateModified: page.updatedAt,
}
---

<Layout title={`${page.title} | RiftMatch`} description={page.seo?.description} lang={locale}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="fr" href={`${BASE}/info/${page.slug}`} />
    <link rel="alternate" hreflang="en" href={`${BASE}/en/info/${page.slug}`} />
    <link rel="alternate" hreflang="es" href={`${BASE}/es/info/${page.slug}`} />
    <link rel="alternate" hreflang="x-default" href={`${BASE}/info/${page.slug}`} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <!-- ════════════════════════════════════════════════════════
       TEMPLATE: ARTICLE (centré, lecture longue)
  ═══════════════════════════════════════════════════════════ -->
  {template === 'article' && (
    <main class="t-article">
      <nav class="breadcrumb" aria-label="Fil d'Ariane">
        <a href="/">{ ta.home }</a><span>›</span><a href={guidesPath}>{ ta.guides }</a><span>›</span><span>{page.title}</span>
      </nav>
      <header class="page-header">
        <h1 class="page-title">{page.title}</h1>
        <p class="page-meta">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          {ta.readingTime(readingMin)}
        </p>
      </header>
      <article class="prose" set:html={htmlContent} />
      <div class="aff-wrap"><AffiliateBlock placement="article-content" variant="banner" locale={locale} /></div>
      <nav class="page-footer-nav">
        <a href={guidesPath} class="back-link">{ta.backLink}</a>
        <a href={quizPath} class="cta-btn">{ta.quizCta}</a>
      </nav>
    </main>
  )}

  <!-- ════════════════════════════════════════════════════════
       TEMPLATE: GUIDE (2 colonnes, sidebar sticky)
  ═══════════════════════════════════════════════════════════ -->
  {template === 'guide' && (
    <main class="t-guide">
      <nav class="breadcrumb" aria-label="Fil d'Ariane">
        <a href="/">{ ta.home }</a><span>›</span><a href={guidesPath}>{ ta.guides }</a><span>›</span><span>{page.title}</span>
      </nav>
      <header class="page-header guide-header">
        <div class="guide-header-badge">{ta.guideBadge}</div>
        <h1 class="page-title">{page.title}</h1>
        <p class="page-meta">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          {ta.guideMeta(readingMin, tocItems.length)}
        </p>
      </header>

      <div class="guide-layout">
        <article class="prose guide-prose" set:html={htmlContent} />

        <aside class="guide-sidebar">
          {tocItems.length > 0 && (
            <div class="toc-card">
              <p class="toc-title">{ta.tocTitle}</p>
              <nav>
                <ol class="toc-list">
                  {tocItems.map((item: {text: string; id: string}, i: number) => (
                    <li>
                      <a href={`#${item.id}`} class="toc-link">
                        <span class="toc-num">{String(i + 1).padStart(2, '0')}</span>
                        {item.text}
                      </a>
                    </li>
                  ))}
                </ol>
              </nav>
            </div>
          )}
          <div class="sidebar-aff">
            <AffiliateBlock placement="article-sidebar" variant="card" locale={locale} />
          </div>
          <a href={quizPath} class="sidebar-quiz-cta">
            <span class="sidebar-quiz-label">{ta.sidebarQuizLabel}</span>
            <span class="sidebar-quiz-title">{ta.sidebarQuizTitle}</span>
            <span class="sidebar-quiz-arrow">{ta.sidebarQuizCta}</span>
          </a>
        </aside>
      </div>

      <div class="aff-wrap"><AffiliateBlock placement="article-content" variant="banner" locale={locale} /></div>
      <nav class="page-footer-nav">
        <a href={guidesPath} class="back-link">{ta.backLink}</a>
        <a href={quizPath} class="cta-btn">{ta.quizCta}</a>
      </nav>
    </main>
  )}

  <!-- ════════════════════════════════════════════════════════
       TEMPLATE: LISTICLE (Top X, sections numérotées)
  ═══════════════════════════════════════════════════════════ -->
  {template === 'listicle' && (
    <main class="t-listicle">
      <nav class="breadcrumb" aria-label="Fil d'Ariane">
        <a href="/">{ ta.home }</a><span>›</span><a href={guidesPath}>{ ta.guides }</a><span>›</span><span>{page.title}</span>
      </nav>

      <header class="listicle-hero">
        <div class="listicle-count">{sections.length}</div>
        <h1 class="listicle-title">{page.title}</h1>
        {page.seo?.description && <p class="listicle-sub">{page.seo.description}</p>}
        <p class="page-meta">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          {ta.readingTime(readingMin)}
        </p>
      </header>

      <div class="listicle-sections">
        {sections.map((section: Section, i: number) => (
          <div class="listicle-item">
            <div class="listicle-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</div>
            <div class="listicle-content">
              <h2 class="listicle-section-title">{section.title}</h2>
              <div class="prose prose--compact" set:html={renderNodes(section.nodes)} />
            </div>
            {i === 2 && (
              <div class="listicle-aff-inline">
                <AffiliateBlock placement="article-content" variant="banner" locale={locale} />
              </div>
            )}
          </div>
        ))}
      </div>

      <div class="aff-wrap" style="margin-top: 2.5rem;"><AffiliateBlock placement="article-content" variant="banner" locale={locale} /></div>
      <nav class="page-footer-nav">
        <a href={guidesPath} class="back-link">{ta.backLink}</a>
        <a href={quizPath} class="cta-btn">{ta.quizCta}</a>
      </nav>
    </main>
  )}
</Layout>

<style is:global>
/* ── Shared ─────────────────────────────────────────── */
.breadcrumb {
  display: flex; align-items: center; gap: 0.4rem;
  font-size: 0.72rem; color: var(--text-dim);
  margin-bottom: 2rem; flex-wrap: wrap;
}
.breadcrumb a { color: var(--text-dim); text-decoration: none; transition: color 0.2s; }
.breadcrumb a:hover { color: var(--gold); }
.breadcrumb span { opacity: 0.5; }
.breadcrumb span:last-child { opacity: 1; color: var(--text-muted); }

.page-header { margin-bottom: 2rem; }
.page-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(1.4rem, 4vw, 2.2rem);
  color: var(--gold-light, #f0e6b2);
  line-height: 1.25; margin-bottom: 0.65rem;
}
.page-meta {
  display: inline-flex; align-items: center; gap: 0.4rem;
  font-size: 0.72rem; color: var(--text-dim);
  font-family: 'Rajdhani', sans-serif; font-weight: 600;
  letter-spacing: 0.05em; text-transform: uppercase;
}
.page-meta svg { width: 13px; height: 13px; }

/* Prose (shared) */
.prose {
  background: rgba(14,17,24,0.7);
  border: 1px solid rgba(200,155,60,0.1);
  border-radius: 14px; padding: 2.25rem;
  line-height: 1.85; color: var(--text-light, #e1e6f0);
  font-size: 1rem;
}
.prose > * + * { margin-top: 1.2rem; }
.prose h2 {
  font-family: 'Cinzel', serif; font-size: 1.2rem;
  color: var(--gold, #c89b3c); margin-top: 2.5rem; margin-bottom: 0.6rem;
  padding-left: 1rem; border-left: 3px solid var(--gold, #c89b3c); line-height: 1.35;
}
.prose h2:first-child { margin-top: 0; }
.prose h3 {
  font-family: 'Rajdhani', sans-serif; font-size: 1.05rem; font-weight: 700;
  letter-spacing: 0.05em; text-transform: uppercase;
  color: var(--text-light); margin-top: 1.75rem; margin-bottom: 0.4rem;
}
.prose p { color: rgba(225,230,240,0.88); }
.prose strong { color: var(--gold-light, #f0e6b2); }
.prose em { color: rgba(225,230,240,0.75); }
.prose a { color: var(--blue, #0bc4e3); text-decoration: underline; text-underline-offset: 3px; transition: color 0.2s; }
.prose a:hover { color: var(--gold); }
.prose ul, .prose ol { margin-left: 1.5rem; }
.prose ul { list-style: disc; } .prose ol { list-style: decimal; }
.prose li { margin-bottom: 0.4rem; color: rgba(225,230,240,0.88); }
.prose blockquote {
  border-left: 3px solid rgba(200,155,60,0.4); padding: 0.75rem 1.25rem;
  background: rgba(200,155,60,0.04); border-radius: 0 8px 8px 0;
  color: rgba(225,230,240,0.75); font-style: italic;
}
.prose code {
  background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
  border-radius: 4px; padding: 0.1em 0.4em; font-size: 0.88em;
  font-family: monospace; color: var(--blue, #0bc4e3);
}
.prose--compact { background: none; border: none; border-radius: 0; padding: 0; font-size: 0.95rem; }

/* Footer nav */
.aff-wrap { margin-top: 2rem; }
.aff-wrap :global(.aff-banner) { margin: 0; }
.page-footer-nav {
  display: flex; align-items: center; justify-content: space-between;
  gap: 1rem; margin-top: 2.5rem; flex-wrap: wrap;
}
.back-link {
  font-size: 0.85rem; color: var(--text-muted); text-decoration: none; transition: color 0.2s;
}
.back-link:hover { color: var(--gold); }
.cta-btn {
  font-family: 'Rajdhani', sans-serif; font-size: 0.85rem; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase; color: #08090d;
  background: linear-gradient(135deg, #d4a43f, #c89b3c);
  padding: 0.6rem 1.4rem; border-radius: 6px; text-decoration: none;
  transition: box-shadow 0.2s, transform 0.2s;
}
.cta-btn:hover { box-shadow: 0 6px 20px rgba(200,155,60,0.4); transform: translateY(-1px); }

/* ── Template: ARTICLE ──────────────────────────────── */
.t-article { max-width: 760px; margin: 0 auto; padding: 1.5rem 1.25rem 5rem; }

/* ── Template: GUIDE ────────────────────────────────── */
.t-guide { max-width: 1100px; margin: 0 auto; padding: 1.5rem 1.25rem 5rem; }

.guide-header-badge {
  display: inline-block;
  font-family: 'Rajdhani', sans-serif; font-size: 0.68rem; font-weight: 700;
  letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--gold); background: rgba(200,155,60,0.1);
  border: 1px solid rgba(200,155,60,0.25); border-radius: 20px;
  padding: 0.2rem 0.75rem; margin-bottom: 0.75rem;
}

.guide-layout {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 2rem;
  align-items: start;
}
.guide-prose { min-width: 0; }

.guide-sidebar {
  display: flex; flex-direction: column; gap: 1.25rem;
  position: sticky; top: 80px;
  max-height: calc(100vh - 96px);
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(200,155,60,0.2) transparent;
}

.toc-card {
  background: rgba(14,17,24,0.8);
  border: 1px solid rgba(200,155,60,0.15);
  border-radius: 12px; padding: 1.25rem;
}
.toc-title {
  font-family: 'Rajdhani', sans-serif; font-size: 0.7rem; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--gold); opacity: 0.8; margin-bottom: 0.85rem;
}
.toc-list { list-style: none; display: flex; flex-direction: column; gap: 0.35rem; }
.toc-link {
  display: flex; align-items: baseline; gap: 0.6rem;
  font-size: 0.82rem; color: var(--text-muted); text-decoration: none;
  transition: color 0.2s; line-height: 1.4; padding: 0.2rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.toc-link:hover { color: var(--gold); }
.toc-num {
  font-family: 'Rajdhani', sans-serif; font-size: 0.65rem; font-weight: 700;
  color: var(--gold); opacity: 0.6; flex-shrink: 0;
}

.sidebar-aff :global(.aff-card) { margin: 0; }

.sidebar-quiz-cta {
  display: flex; flex-direction: column; gap: 0.3rem;
  background: linear-gradient(135deg, rgba(200,155,60,0.12), rgba(11,196,227,0.06));
  border: 1px solid rgba(200,155,60,0.25); border-radius: 12px;
  padding: 1.1rem 1.25rem; text-decoration: none;
  transition: border-color 0.25s, transform 0.2s;
}
.sidebar-quiz-cta:hover { border-color: rgba(200,155,60,0.5); transform: translateY(-2px); }
.sidebar-quiz-label {
  font-family: 'Rajdhani', sans-serif; font-size: 0.65rem; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); opacity: 0.8;
}
.sidebar-quiz-title { font-size: 0.95rem; font-weight: 700; color: var(--gold-light); line-height: 1.3; }
.sidebar-quiz-arrow { font-size: 0.78rem; color: var(--gold); margin-top: 0.25rem; }

@media (max-width: 860px) {
  .guide-layout { grid-template-columns: 1fr; }
  .toc-card { position: static; }
  .guide-sidebar { order: -1; }
}

/* ── Template: LISTICLE ─────────────────────────────── */
.t-listicle { max-width: 820px; margin: 0 auto; padding: 1.5rem 1.25rem 5rem; }

.listicle-hero {
  text-align: center; margin-bottom: 3.5rem;
  padding: 2rem 1rem 2.5rem;
  border-bottom: 1px solid rgba(200,155,60,0.1);
}
.listicle-count {
  font-family: 'Russo One', sans-serif;
  font-size: 5rem; line-height: 1;
  background: linear-gradient(135deg, #f0e6b2, #c89b3c);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text; opacity: 0.25;
  margin-bottom: -0.5rem;
}
.listicle-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(1.4rem, 4vw, 2.2rem);
  color: var(--gold-light); line-height: 1.2; margin-bottom: 0.75rem;
}
.listicle-sub { font-size: 0.95rem; color: var(--text-muted); max-width: 540px; margin: 0 auto 0.75rem; line-height: 1.6; }

.listicle-sections { display: flex; flex-direction: column; gap: 1.5rem; }

.listicle-item {
  display: grid;
  grid-template-columns: 64px 1fr;
  gap: 0 1.5rem;
  align-items: start;
  background: rgba(14,17,24,0.6);
  border: 1px solid rgba(200,155,60,0.1);
  border-radius: 14px; padding: 1.75rem 1.75rem 1.75rem 0;
  transition: border-color 0.25s;
  overflow: hidden;
}
.listicle-item:hover { border-color: rgba(200,155,60,0.3); }

.listicle-num {
  font-family: 'Russo One', sans-serif; font-size: 1.6rem;
  background: linear-gradient(135deg, rgba(200,155,60,0.6), rgba(200,155,60,0.2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  text-align: center; padding-top: 0.1rem; line-height: 1;
  border-right: 1px solid rgba(200,155,60,0.1);
  display: flex; align-items: flex-start; justify-content: center; padding-left: 1.5rem;
}

.listicle-section-title {
  font-family: 'Cinzel', serif !important;
  font-size: 1.1rem !important; color: var(--gold-light) !important;
  margin-bottom: 0.75rem; line-height: 1.35;
  border: none !important; padding: 0 !important; margin-top: 0 !important;
}
.listicle-content .prose--compact > * + * { margin-top: 0.75rem; }

.listicle-aff-inline {
  grid-column: 1 / -1;
  padding: 0 1.75rem 0 0;
  margin-top: 0.5rem;
}

@media (max-width: 500px) {
  .t-article, .t-guide, .t-listicle { padding: 1rem 0.75rem 4rem; }
  .prose { padding: 1.5rem 1.1rem; }
  .listicle-item { grid-template-columns: 48px 1fr; padding-right: 1.25rem; }
  .page-footer-nav { flex-direction: column; align-items: flex-start; }
  .cta-btn { width: 100%; text-align: center; }
}
</style>
