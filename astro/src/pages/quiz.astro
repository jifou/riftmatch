---
import Layout from '../layouts/Layout.astro'
import { QUIZ, LEVEL_QUESTION, UI } from '../i18n'
import { CHAMPIONS } from '../data/champions'
import AffiliateBlock from '../components/AffiliateBlock.astro'

const locale = Astro.cookies.get('locale')?.value || 'fr'
const safeLocale = (QUIZ as any)[locale] ? locale : 'fr'
const quizData = (QUIZ as any)[safeLocale]
const levelQ = (LEVEL_QUESTION as any)[safeLocale]
const t = (UI as any)[safeLocale] || (UI as any).fr
---

<Layout
  title={t.quizPage.title}
  description={t.quizPage.description}
  lang={locale}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "name": "Quiz – Trouve ton champion LoL",
    "url": "https://riftmatch.io/quiz",
    "description": "Quiz de personnalité pour trouver le champion League of Legends qui vous correspond.",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Comment fonctionne le quiz RiftMatch ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Réponds à 7 questions sur ton style de jeu, ta personnalité et tes préférences. L'algorithme analyse tes réponses et te propose les 3 champions League of Legends qui te correspondent le mieux."
        }
      },
      {
        "@type": "Question",
        "name": "Le quiz est-il gratuit ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui, le quiz RiftMatch est entièrement gratuit et ne nécessite aucune inscription."
        }
      },
      {
        "@type": "Question",
        "name": "Combien de champions sont disponibles ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "RiftMatch couvre l'ensemble des champions League of Legends disponibles sur le patch actuel."
        }
      }
    ]
  })} />
  <main class="quiz-container">
    <div id="quiz-app"
      data-champions={JSON.stringify(CHAMPIONS)}
      data-quiz={JSON.stringify(quizData)}
      data-levelq={JSON.stringify(levelQ)}
      data-i18n={JSON.stringify({
        tierSDesc:       t.quizPage.tierSDesc,
        tierADesc:       t.quizPage.tierADesc,
        tierBDesc:       t.quizPage.tierBDesc,
        difficulties:    t.quizPage.difficulties,
        championCta:     t.quizPage.championCta,
        championCtaShort:t.quizPage.championCtaShort,
        champBase:       locale === 'fr' ? '/champion' : `/${locale}/champion`,
      })}
    >
      <!-- Quiz screen -->
      <div id="quiz-screen">
        <div class="quiz-topbar">
          <button id="back-btn" class="nav-btn" aria-label={t.quizPage.backAriaLabel}>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M10 13L5 8l5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="progress-wrap" aria-label={t.quizPage.progressAriaLabel}>
            <div class="progress-track">
              <div id="prog-fill" class="progress-fill"></div>
            </div>
          </div>
          <span id="prog-count" class="progress-count">1/7</span>
        </div>

        <div class="quiz-card">
          <div id="quiz-badge" class="quiz-badge" aria-live="polite" aria-atomic="true">{t.quizPage.loadingBadge}</div>
          <h1 id="quiz-q" class="quiz-q">{t.quizPage.loadingQuestion}</h1>
          <div id="answers" class="answers"></div>
        </div>
      </div>

      <!-- Results screen -->
      <div id="results-screen" style="display: none;">
        <div class="results-header hex-bg">
          <div class="results-icon" aria-hidden="true">✨</div>
          <h1 class="results-title">{t.quizPage.resultsTitle}</h1>
          <p class="results-sub">{t.quizPage.resultsSub}</p>
          <div class="results-tiers-legend">
            <span class="legend-item"><b class="tier-s">S</b> {t.quizPage.tierS}</span>
            <span class="legend-sep">·</span>
            <span class="legend-item"><b class="tier-a">A</b> {t.quizPage.tierA}</span>
            <span class="legend-sep">·</span>
            <span class="legend-item"><b class="tier-b">B</b> {t.quizPage.tierB}</span>
          </div>
        </div>

        <div id="champs-wrapper" class="champs-wrapper"></div>
        <div id="mobile-dots" class="mobile-dots" aria-hidden="true"></div>

        <AffiliateBlock placement="quiz-results" variant="card" locale={locale} />

        <button id="restart-btn" class="restart-btn">
          {t.quizPage.restartBtn}
        </button>

        <AffiliateBlock placement="quiz-results-bottom" variant="banner" locale={locale} />
      </div>
    </div>
  </main>
</Layout>

<script>
  import { calculateResults } from '../lib/quiz.js'

  const app = document.getElementById('quiz-app')!
  const champions = JSON.parse((app as HTMLElement).dataset.champions || '[]')
  const quizData = JSON.parse((app as HTMLElement).dataset.quiz || '{}')
  const levelQ = JSON.parse((app as HTMLElement).dataset.levelq || '{}')
  const i18n = JSON.parse((app as HTMLElement).dataset.i18n || '{}')

  const _tierSDesc        = i18n.tierSDesc        || ''
  const _tierADesc        = i18n.tierADesc        || ''
  const _tierBDesc        = i18n.tierBDesc        || ''
  const _difficulties     = i18n.difficulties     || []
  const _champCta         = i18n.championCta      || '→'
  const _champCtaShort    = i18n.championCtaShort || '→'
  const _champBase        = i18n.champBase        || '/champion'

  const DDR_LOADING = 'https://ddragon.leagueoflegends.com/cdn/img/champion/loading'

  const currentPath = new URLSearchParams(window.location.search).get('path') || 'character'
  const pathQuestions = quizData[currentPath]?.questions || []
  const allQuestions = [levelQ, ...pathQuestions]
  const totalSteps = allQuestions.length

  let step = 0
  let playerLevel = 1
  let answers: number[] = []

  function init() {
    renderQuestion()
    document.getElementById('back-btn')!.onclick = goBack
    document.getElementById('restart-btn')!.onclick = () => window.location.href = '/'
  }

  function renderQuestion() {
    const q = allQuestions[step]
    if (!q) return showResults()

    const pct = (step / totalSteps) * 100
    const fill = document.getElementById('prog-fill')!
    fill.style.width = `${pct}%`
    document.getElementById('prog-count')!.textContent = `${step + 1}/${totalSteps}`
    document.getElementById('quiz-q')!.textContent = q.q
    document.getElementById('quiz-badge')!.textContent = step === 0
      ? (q.badge || '🎮 Niveau')
      : `⚡ Question ${step} / ${totalSteps - 1}`

    const container = document.getElementById('answers')!
    container.innerHTML = ''

    // Animate in
    const card = document.querySelector('.quiz-card') as HTMLElement
    if (card) {
      card.style.opacity = '0'
      card.style.transform = 'translateY(12px)'
      requestAnimationFrame(() => {
        card.style.transition = 'opacity 0.3s ease, transform 0.3s ease'
        card.style.opacity = '1'
        card.style.transform = 'translateY(0)'
      })
    }

    q.a.forEach((ans: { i: string; t: string; level?: number }, idx: number) => {
      const btn = document.createElement('button')
      btn.className = 'answer-btn'
      btn.innerHTML = `
        <span class="ans-icon">${ans.i}</span>
        <span class="ans-text">${ans.t}</span>
        <span class="ans-arrow" aria-hidden="true">→</span>
      `
      btn.onclick = () => pickAnswer(idx, ans)
      container.appendChild(btn)
    })
  }

  function pickAnswer(idx: number, ans: { level?: number }) {
    if (step === 0) {
      playerLevel = ans.level ?? idx
    } else {
      answers.push(idx)
    }
    step++
    if (step < totalSteps) {
      renderQuestion()
    } else {
      showResults()
    }
  }

  function goBack() {
    if (step === 0) {
      window.location.href = '/'
    } else if (step === 1) {
      step--
      playerLevel = 1
      renderQuestion()
    } else {
      step--
      answers.pop()
      renderQuestion()
    }
  }

  function showResults() {
    const quizScreen = document.getElementById('quiz-screen')!
    const resultsScreen = document.getElementById('results-screen')!

    quizScreen.style.opacity = '0'
    quizScreen.style.transform = 'scale(0.97)'
    setTimeout(() => {
      quizScreen.style.display = 'none'
      resultsScreen.style.display = 'block'
      resultsScreen.style.opacity = '0'
      // Full-viewport layout on mobile
      document.querySelector('.quiz-container')?.classList.add('results-active')
      window.scrollTo({ top: 0, behavior: 'instant' })
      // Forcer le flex layout sur mobile (le CSS seul ne suffit pas avec display:block inline)
      if (window.innerWidth <= 600) {
        resultsScreen.style.display = 'flex'
        resultsScreen.style.flexDirection = 'column'
        resultsScreen.style.height = `calc(100dvh - 64px)`
        resultsScreen.style.overflow = 'hidden'
        resultsScreen.style.width = '100vw'
        resultsScreen.style.marginLeft = '0'
        resultsScreen.style.transform = 'none'
      }
      requestAnimationFrame(() => {
        resultsScreen.style.transition = 'opacity 0.4s ease'
        resultsScreen.style.opacity = '1'
      })
    }, 300)

    const results = calculateResults(champions, currentPath, answers, playerLevel)
    const wrapper = document.getElementById('champs-wrapper')!

    const tiers = [
      { label: 'S', color: '#f0e6b2', glow: 'rgba(240,230,178,0.35)', desc: _tierSDesc },
      { label: 'A', color: '#c0d0e0', glow: 'rgba(192,208,224,0.25)', desc: _tierADesc },
      { label: 'B', color: '#a07850', glow: 'rgba(160,120,80,0.2)',  desc: _tierBDesc },
    ]

    // Top result — full-width hero card
    const top = results[0]
    const t0 = tiers[0]
    // Ordre affiché : A (gauche), S (centre), B (droite)
    const display = [results[1], results[0], results[2]]
    const displayTiers = [tiers[1], tiers[0], tiers[2]]

    function diffStars(d: number) {
      return '★'.repeat(d) + '☆'.repeat(5 - d)
    }
    function diffLabel(d: number) {
      return _difficulties[d] || ''
    }
    function diffColor(d: number) {
      return ['','#22c55e','#86efac','#fbbf24','#f97316','#ef4444'][d] || '#fbbf24'
    }

    wrapper.innerHTML = `<div class="results-grid" id="results-grid">${display.map((c: any, i: number) => {
      const t = displayTiers[i]
      const isTop = t.label === 'S'
      const dc = diffColor(c.difficulty)
      return `
        <a href="${_champBase}/${c.apiId}" class="champ-result${isTop ? ' champ-result--s' : ' champ-result--secondary'}">
          ${isTop ? `
            <div class="tier-crown" aria-hidden="true">
              <svg width="28" height="24" viewBox="0 0 32 28" fill="none">
                <path d="M2 24L6 8L14 16L16 4L18 16L26 8L30 24H2Z" fill="${t.color}" opacity="0.9"/>
                <circle cx="2" cy="24" r="2.5" fill="${t.color}"/>
                <circle cx="16" cy="4" r="2.5" fill="${t.color}"/>
                <circle cx="30" cy="24" r="2.5" fill="${t.color}"/>
              </svg>
            </div>
          ` : ''}
          <div class="tier-badge tier-badge--${t.label.toLowerCase()}" style="--tier-color:${t.color}; --tier-glow:${t.glow}">${t.label}</div>
          <div class="champ-result-img-wrap">
            <img src="${DDR_LOADING}/${c.apiId}_0.jpg" alt="${c.name}" loading="lazy"/>
            <div class="champ-result-overlay"></div>
            <div class="champ-result-scanlines" aria-hidden="true"></div>
            ${isTop ? `
              <div class="champ-result-particles" aria-hidden="true">
                ${Array.from({length:5}, (_,pi) => `<span class="particle" style="--i:${pi}"></span>`).join('')}
              </div>
            ` : ''}
          </div>
          <div class="champ-result-info">
            <h3 class="champ-result-name${isTop ? ' champ-result-name--s' : ''}">${c.name}</h3>
            <p class="champ-result-faction">${c.faction}</p>
            <div class="diff-row-result">
              <span class="diff-stars-result" style="color:${dc}" title="Difficulté ${c.difficulty}/5">${diffStars(c.difficulty)}</span>
              <span class="diff-label-result" style="color:${dc}">${diffLabel(c.difficulty)}</span>
            </div>
            <div class="champ-result-match">
              <div class="match-track">
                <div class="match-fill${isTop ? ' match-fill--s' : ''}" style="width:${c.matchPct}%"></div>
              </div>
              <span class="match-label${isTop ? ' match-label--s' : ''}">${c.matchPct}% compat.</span>
            </div>
            <span class="champ-result-cta">${isTop ? _champCta : _champCtaShort}</span>
          </div>
        </a>
      `
    }).join('')}</div>`

    // Mobile option 3 : hero S + mini A/B row, tout visible d'un coup
    if (window.innerWidth <= 600) {
      // Empêcher le pull-to-refresh qui perturbe l'interaction
      document.body.style.overscrollBehavior = 'contain'
      // Bouton refaire flottant sur la S card
      const sCard = wrapper.querySelector<HTMLElement>('.champ-result--s')
      if (sCard) {
        const refaire = document.createElement('a')
        refaire.href = '/quiz'
        refaire.className = 'mobile-refaire-btn'
        refaire.textContent = '↩ Refaire'
        sCard.appendChild(refaire)
      }
    }
  }

  init()
</script>

<style is:global>
  .quiz-container {
    max-width: 640px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 5rem;
    min-height: 80vh;
  }

  /* ── Topbar ── */
  .quiz-topbar {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px; height: 38px;
    background: var(--dark3);
    border: 1px solid rgba(200,155,60,0.2);
    color: var(--gold);
    cursor: pointer;
    border-radius: 8px;
    flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }
  .nav-btn:hover {
    background: var(--dark4);
    border-color: var(--gold);
    color: var(--gold-light);
  }
  .progress-wrap { flex: 1; }
  .progress-track {
    height: 5px;
    background: rgba(255,255,255,0.07);
    border-radius: 3px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold), #e8c96a);
    border-radius: 3px;
    transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 0 8px rgba(200,155,60,0.4);
  }
  .progress-count {
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Quiz card ── */
  .quiz-card {
    background: var(--glass-bg, rgba(15,18,28,0.75));
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border, rgba(200,155,60,0.18));
    border-radius: 14px;
    padding: 2rem 1.75rem 2.5rem;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .quiz-badge {
    display: inline-flex;
    align-items: center;
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(200,155,60,0.08);
    border: 1px solid rgba(200,155,60,0.25);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    margin-bottom: 1.25rem;
  }

  .quiz-q {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.2rem, 3.5vw, 1.6rem);
    color: var(--text-light);
    margin-bottom: 2rem;
    line-height: 1.35;
  }

  /* ── Answers ── */
  .answers { display: grid; gap: 0.65rem; }

  .answer-btn {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    width: 100%;
    padding: 1rem 1.1rem;
    background: var(--dark3);
    border: 1px solid rgba(200,155,60,0.12);
    border-radius: 9px;
    color: var(--text-light);
    cursor: pointer;
    text-align: left;
    font-size: 0.93rem;
    font-family: 'Inter', sans-serif;
    transition: background 0.18s, border-color 0.18s, transform 0.18s, box-shadow 0.18s;
    position: relative;
    overflow: hidden;
  }
  .answer-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(200,155,60,0.06), transparent);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .answer-btn:hover {
    background: var(--dark4);
    border-color: rgba(200,155,60,0.45);
    transform: translateX(4px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.25), -3px 0 0 var(--gold);
  }
  .answer-btn:hover::before { opacity: 1; }
  .answer-btn:active { transform: translateX(2px) scale(0.99); }

  .ans-icon {
    font-size: 1.4rem;
    flex-shrink: 0;
    width: 2rem;
    text-align: center;
  }
  .ans-text { flex: 1; line-height: 1.3; }
  .ans-arrow {
    font-size: 0.9rem;
    color: var(--gold);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s, transform 0.2s;
    flex-shrink: 0;
  }
  .answer-btn:hover .ans-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Results ── */
  /* Results : break out du container 640px pour s'étaler sur desktop */
  #results-screen {
    transition: opacity 0.4s ease;
    width: min(920px, calc(100vw - 2.5rem));
    margin-left: 50%;
    transform: translateX(-50%);
    position: relative;
  }

  .results-header {
    text-align: center;
    margin-bottom: 1rem;
    padding: 1.1rem 1rem 0.9rem;
    border-radius: 12px;
    border: 1px solid rgba(200,155,60,0.1);
    background: rgba(14,17,24,0.5);
  }
  .results-icon {
    font-size: 2rem;
    margin-bottom: 0.4rem;
    animation: crown-float 3s ease-in-out infinite;
    display: inline-block;
  }
  .results-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.2rem, 3.5vw, 1.6rem);
    color: var(--gold-light);
    margin-bottom: 0.3rem;
    text-shadow: 0 0 20px rgba(200,155,60,0.3);
  }
  .results-sub {
    font-size: 0.82rem;
    color: var(--text-muted);
    max-width: 380px;
    margin: 0 auto 0.6rem;
    line-height: 1.5;
  }
  .results-tiers-legend {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }
  .legend-item { display: flex; align-items: center; gap: 0.3rem; }
  .legend-item b {
    font-family: 'Cinzel', serif;
    font-size: 0.9rem;
    font-weight: 900;
  }
  .legend-sep { opacity: 0.3; }

  /* Dots cachés par défaut, visibles uniquement via media query mobile */
  .mobile-dots { display: none; }

  /* ── Results wrapper ── */
  .champs-wrapper {
    margin-bottom: 2rem;
  }
  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  /* ── Mobile : cartes plein écran, scroll horizontal snappé ── */

  /* Quand les résultats sont affichés, reset le container pour pleine largeur */
  .quiz-container.results-active {
    padding-left: 0 !important;
    padding-right: 0 !important;
    max-width: 100vw !important;
    overflow: visible;
  }

  @media (max-width: 600px) {
    /* Results screen : plein viewport */
    .quiz-container.results-active #results-screen {
      width: 100vw;
      margin-left: 0;
      transform: none;
      height: calc(100dvh - 64px); /* viewport - navbar fixe */
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* Header ultra-compact */
    .quiz-container.results-active .results-header {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      flex-wrap: wrap;
      padding: 0.55rem 1rem 0.45rem;
      margin-bottom: 0;
      border-radius: 0;
      border-left: none;
      border-right: none;
    }
    .quiz-container.results-active .results-icon { display: none; }
    .quiz-container.results-active .results-sub  { display: none; }
    .quiz-container.results-active .results-title {
      font-size: 0.88rem;
      margin: 0;
      white-space: nowrap;
    }
    .quiz-container.results-active .results-tiers-legend { margin: 0; }

    /* ── Option 3 : Hero S + mini A/B row ── */

    /* Wrapper = conteneur sans scroll */
    .quiz-container.results-active .champs-wrapper {
      flex: 1;
      min-height: 0;
      overflow: hidden;
      margin: 0;
      width: 100vw;
      padding: 0.5rem 0.5rem 0;
      box-sizing: border-box;
    }

    /* Grid 2 cols, 2 rows : S en haut full-width, A+B en bas */
    .quiz-container.results-active .results-grid {
      display: grid !important;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 58% 42%;
      grid-template-areas:
        "s s"
        "a b";
      height: 100%;
      gap: 0.4rem;
      padding: 0;
    }

    /* Assignation des zones */
    .quiz-container.results-active .champ-result--s              { grid-area: s; }
    .quiz-container.results-active .champ-result--secondary:first-child { grid-area: a; }
    .quiz-container.results-active .champ-result--secondary:last-child  { grid-area: b; }

    /* Toutes les cartes : image absolute + overlay */
    .quiz-container.results-active .champ-result {
      position: relative;
      overflow: hidden;
      border-radius: 14px;
      width: 100%;
      height: 100%;
    }
    .quiz-container.results-active .champ-result-img-wrap {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }
    .quiz-container.results-active .champ-result-img-wrap img,
    .quiz-container.results-active .champ-result--s .champ-result-img-wrap img {
      height: 100% !important;
      width: 100%;
      object-fit: cover;
      object-position: top center;
    }

    /* Overlay info en bas */
    .quiz-container.results-active .champ-result-info {
      position: absolute;
