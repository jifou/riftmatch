# ══════════════════════════════════════════════════════
#  RiftMatch — Variables d'environnement (PROD)
#  Copier ce fichier en .env.production et remplir
# ══════════════════════════════════════════════════════

# ── MongoDB ──────────────────────────────────────────
# MongoDB tourne dans Docker sur le même VPS — pas besoin d'Atlas
# (docker-compose.prod.yml utilise directement mongodb://mongo:27017/lolpersonnality)

# ── Payload CMS ──────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=CHANGE_ME_32_CHARS_MIN

# ── Affiliation Amazon ────────────────────────────────
# Ton tag Amazon Partenaires (partenaires.amazon.fr)
# Format : nomdusite-21
AMAZON_AFFILIATE_TAG=riftmatchio-21

# ── Google Analytics ──────────────────────────────────
# Measurement ID depuis Google Analytics → Admin → Flux de données
# Format : G-XXXXXXXXXX — laisser vide pour désactiver
PUBLIC_GA_ID=
